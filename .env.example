# .env.example — copy to .env and fill in the [SET] values.
# All keys OLLEN_RAG_*-prefixed (see src/settings.py) except HF_HUB_OFFLINE; unknown keys ignored.
#
# ── HOW TO READ THIS FILE ─────────────────────────────────────────────
#   §1 CONTROL PANEL picks the providers; every block below is tagged:
#     ACTIVE WHEN <selection>  — block is used only under that selection, else inert.
#     [SET]      you must supply this value (credential / project id).
#     [pick]     choose one of the listed values.
#     (default)  safe to leave as-is.
#   Only the blocks matching your §1 selection need real values; leave the rest as shipped.

# ======================================================================
# §1  CONTROL PANEL — provider selection (drives every block below)
# ======================================================================
# [pick] watsonx (native SDK) | litellm | litellm-watsonx | litellm-ollama | litellm-openai | litellm-openrouter
OLLEN_RAG_LLM_PROVIDER=litellm-watsonx
# [pick] watsonx | fastembed | litellm | litellm-watsonx | litellm-ollama | litellm-openai | litellm-openrouter
OLLEN_RAG_EMBEDDING_PROVIDER=watsonx
# [pick] sentence-transformers (local) | litellm | litellm-watsonx
# (Ollama exposes no rerank endpoint, so there is no litellm-ollama reranker.)
OLLEN_RAG_RERANKER_PROVIDER=sentence-transformers
# [pick] opensearch (dense+sparse+hybrid) | chroma (embedded, dense-only)
# NOTE: this file's default is opensearch (the plain-Python dev default). Docker compose seeds a
# fresh .env with chroma instead (so `docker compose up` needs nothing external) -- as real .env
# content, not a fixed env var, so switching back to opensearch from the Settings UI later works.
# OpenSearch itself is opt-in there too: `docker compose --profile opensearch up -d`.
OLLEN_RAG_VECTOR_STORE=opensearch

# ======================================================================
# §2  watsonx backend
#     ACTIVE WHEN any of LLM/EMBEDDING/RERANKER provider = watsonx or litellm-watsonx
# ======================================================================
OLLEN_RAG_WATSONX_URL=https://eu-de.ml.cloud.ibm.com
# [SET] required credentials (markers live on their own line — an inline "# ..." after an EMPTY
# value is NOT stripped by pydantic-settings and becomes the value):
OLLEN_RAG_WATSONX_APIKEY=changeme
OLLEN_RAG_WATSONX_PROJECT_ID=changeme
OLLEN_RAG_WATSONX_LLM_MODEL_ID=meta-llama/llama-3-3-70b-instruct
OLLEN_RAG_WATSONX_EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr
# Bare model id for the litellm-watsonx reranker; the "watsonx/" prefix is added at call time.
OLLEN_RAG_WATSONX_RERANKER_MODEL_ID=cross-encoder/ms-marco-minilm-l-12-v2
# generation tuning
OLLEN_RAG_WATSONX_MAX_NEW_TOKENS=1200
OLLEN_RAG_WATSONX_TEMPERATURE=0.1
# Only the native watsonx connector sends this; litellm-watsonx must not (LiteLLM rejects it on
# watsonx's /text/chat endpoint, where it does not exist).
OLLEN_RAG_WATSONX_REPETITION_PENALTY=1.15

# ======================================================================
# §3  LiteLLM backend
#     ACTIVE WHEN any provider = litellm  (litellm-watsonx/-ollama reuse §2/§6 instead)
# ======================================================================
# Generic provider only: full LiteLLM model string, e.g. openai/gpt-4o, groq/llama-3.3-70b-versatile
# [SET] for provider=litellm. API_BASE optional — leave EMPTY to use the vendor's default endpoint.
OLLEN_RAG_LITELLM_MODEL=
OLLEN_RAG_LITELLM_API_BASE=
OLLEN_RAG_LITELLM_API_KEY=
OLLEN_RAG_LITELLM_MAX_NEW_TOKENS=800
OLLEN_RAG_LITELLM_TEMPERATURE=0.1
# Per-modality overrides. Empty → fall back to the shared MODEL/API_BASE/API_KEY above, so a
# single-vendor setup needs only the shared pair, while split hosts (local embeddings, hosted
# generation) stay expressible.
OLLEN_RAG_LITELLM_EMBEDDING_MODEL=
OLLEN_RAG_LITELLM_EMBEDDING_API_BASE=
OLLEN_RAG_LITELLM_EMBEDDING_API_KEY=
# e.g. cohere/rerank-v3.5, jina_ai/jina-reranker-v2-base-multilingual
OLLEN_RAG_LITELLM_RERANK_MODEL=
OLLEN_RAG_LITELLM_RERANK_API_BASE=
OLLEN_RAG_LITELLM_RERANK_API_KEY=

# ======================================================================
# §4  OpenAI / OpenAI-compatible API (served via LiteLLM)
#     ACTIVE WHEN LLM or EMBEDDING provider = litellm-openai
# ======================================================================
# Bare model names; the connector prepends "openai/" automatically.
# [SET] for provider=litellm-openai.
OLLEN_RAG_OPENAI_MODEL=gpt-4o-mini
OLLEN_RAG_OPENAI_API_KEY=changeme
# Leave EMPTY to use the official OpenAI endpoint; set to reach an OpenAI-compatible server
# (vLLM, LocalAI, LM Studio, …), e.g. http://localhost:8080/v1
OLLEN_RAG_OPENAI_API_BASE=
OLLEN_RAG_OPENAI_MAX_NEW_TOKENS=800
OLLEN_RAG_OPENAI_TEMPERATURE=0.1
OLLEN_RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ======================================================================
# §5  OpenRouter (served via LiteLLM)
#     ACTIVE WHEN LLM or EMBEDDING provider = litellm-openrouter
# ======================================================================
# Bare "<vendor>/<model>" tags, e.g. google/gemini-2.5-flash; the connector prepends
# "openrouter/" automatically.
# [SET] for provider=litellm-openrouter.
OLLEN_RAG_OPENROUTER_MODEL=google/gemini-2.5-flash
OLLEN_RAG_OPENROUTER_API_KEY=changeme
# Leave EMPTY to use OpenRouter's own endpoint.
OLLEN_RAG_OPENROUTER_API_BASE=
OLLEN_RAG_OPENROUTER_MAX_NEW_TOKENS=800
OLLEN_RAG_OPENROUTER_TEMPERATURE=0.1
# OpenRouter's embedding-model catalog is scarce; leave EMPTY unless you know a specific one exists.
OLLEN_RAG_OPENROUTER_EMBEDDING_MODEL=

# ======================================================================
# §6  Ollama backend (served via LiteLLM)
#     ACTIVE WHEN LLM or EMBEDDING provider = litellm-ollama
# ======================================================================
# Bare model tags; the connector prefixes them with "ollama/". The chat model cannot embed,
# so embeddings get their own tag.
OLLEN_RAG_OLLAMA_API_BASE=http://localhost:11434
OLLEN_RAG_OLLAMA_MODEL=llama3.1:8b
OLLEN_RAG_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ======================================================================
# §7  fastembed backend
#     ACTIVE WHEN EMBEDDING provider = fastembed
# ======================================================================
OLLEN_RAG_FASTEMBED_MODEL_NAME=jinaai/jina-embeddings-v2-base-code

# ======================================================================
# §8  Vector store
# ======================================================================
# ── Chroma ── ACTIVE WHEN VECTOR_STORE=chroma
# On-disk location of the embedded Chroma store.
OLLEN_RAG_CHROMA_PATH=./chroma_db
# ── OpenSearch ── ACTIVE WHEN VECTOR_STORE=opensearch
OLLEN_RAG_OPENSEARCH_URL=http://localhost:9200
OLLEN_RAG_OPENSEARCH_USER=
OLLEN_RAG_OPENSEARCH_PASSWORD=
OLLEN_RAG_OPENSEARCH_VERIFY_CERTS=true
# hybrid search: score-normalization pipeline + fusion weights [sparse, dense]
OLLEN_RAG_OPENSEARCH_HYBRID_PIPELINE=ollen-rag-hybrid
OLLEN_RAG_HYBRID_SPARSE_WEIGHT=0.5
OLLEN_RAG_HYBRID_DENSE_WEIGHT=0.5

# ======================================================================
# §9  Chunking  (always active)
# ======================================================================
OLLEN_RAG_DEFAULT_CHUNKING_STRATEGY=sentence
OLLEN_RAG_CHUNK_SIZE=512
OLLEN_RAG_CHUNK_OVERLAP=128
OLLEN_RAG_SEMANTIC_BREAKPOINT_PERCENTILE=95
OLLEN_RAG_SENTENCE_WINDOW_SIZE=3
OLLEN_RAG_LLM_CHUNK_MAX_SIZE=1000
OLLEN_RAG_LLM_CHUNK_WINDOW_SIZE=2

# ======================================================================
# §10  Retrieval & rerank  (always active)
# ======================================================================
OLLEN_RAG_RETRIEVAL_TOP_K=10
OLLEN_RAG_RERANK_TOP_N=4
# fused-score floor (0.0 = disabled)
OLLEN_RAG_SIMILARITY_THRESHOLD=0.0
# ACTIVE WHEN RERANKER_PROVIDER=sentence-transformers. Multilingual (mMARCO, Apache-2.0);
# see config/reranker_models.yaml for the alternatives.
OLLEN_RAG_RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
# NOTE: inert. pydantic-settings reads .env into Settings fields, never into os.environ, and
# Settings ignores unknown keys — so HuggingFace never sees this. Export it from the shell if
# offline loading is actually wanted.
HF_HUB_OFFLINE=1

# ======================================================================
# §11  Generation  (always active)
# ======================================================================
OLLEN_RAG_CITATION_CHUNK_SIZE=512
OLLEN_RAG_PROMPTS_DIR=config/prompts
# [pick] rag_answer_en (English, default) | rag_answer_it (Italian) | any config/prompts/<name>.yaml
OLLEN_RAG_DEFAULT_PROMPT_NAME=rag_answer_en

# ======================================================================
# §12  Ingestion — LLM keyword enrichment (overridable per request)
# ======================================================================
OLLEN_RAG_ENRICH_KEYWORDS=false

# ======================================================================
# §13  Eval harness
# ======================================================================
OLLEN_RAG_EVAL_DIR=config/eval

# ======================================================================
# §14  Logging: DEBUG for per-chunk detail (keywords, skipped fragments, threshold cuts)
# ======================================================================
OLLEN_RAG_LOG_LEVEL=INFO